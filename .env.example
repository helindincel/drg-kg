# =============================================================================
# DRG environment template
# Copy to `.env` and fill in the values you need. NEVER commit `.env`.
# =============================================================================

# ---- LLM model (DSPy / LiteLLM provider-prefixed identifier) ----------------
# Examples:
#   openai/gpt-4o-mini
#   gemini/gemini-2.0-flash-exp
#   anthropic/claude-3-5-sonnet
#   ollama_chat/llama3
DRG_MODEL=openai/gpt-4o-mini

# ---- Provider API keys (only set the one(s) you use) ------------------------
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=
OPENROUTER_API_KEY=

# ---- Optional LLM tuning ----------------------------------------------------
DRG_TEMPERATURE=0.0
DRG_MAX_TOKENS=1500
# DRG_BASE_URL=http://localhost:11434  # e.g. Ollama / self-hosted gateway

# ---- Chunking ---------------------------------------------------------------
# DRG_CHUNK_SIZE=768
# DRG_OVERLAP_RATIO=0.15
# DRG_CHUNKING_STRATEGY=token

# ---- API server -------------------------------------------------------------
# DRG_API_PORT=8000
